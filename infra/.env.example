# Copy to infra/.env and fill in real values. Do NOT commit the real .env.

# Postgres
POSTGRES_DB=halilov
POSTGRES_USER=halilov
POSTGRES_PASSWORD=change-me-strong-password

# Backend — JWT signing key. Must be 32+ chars.
#   Generate: openssl rand -base64 48
JWT_SECRET=change-me-very-long-random-string-32+chars-minimum

# First-boot admin user (seeded only if no row with this email exists).
# Pick a real email + strong password before deploy.
INIT_ADMIN_EMAIL=admin@halilov.local
INIT_ADMIN_PASSWORD=change-me-strong-admin-password
INIT_ADMIN_FULL_NAME=Admin

# Media storage. "local" writes to the `media` named volume (default).
# Switch to "r2" to push uploads to Cloudflare R2 (S3-compatible).
MEDIA_STORAGE=local

# Cloudflare R2 — only needed when MEDIA_STORAGE=r2.
#   R2_ENDPOINT:        https://<accountid>.r2.cloudflarestorage.com
#   R2_PUBLIC_BASE_URL: https://pub-<hash>.r2.dev  (or your custom domain, no trailing slash)
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# Transactional email. Provider "log" (default) just logs the send to stdout
# — useful for dev. Switch to "brevo" to actually send via Brevo (free 300/day).
#   1. Sign up at brevo.com, verify a sender domain or single sender email.
#   2. Generate an API key (SMTP & API → API keys → v3).
#   3. Set EMAIL_PROVIDER=brevo + EMAIL_FROM=<verified sender> + BREVO_API_KEY.
#   4. Optional: EMAIL_ADMIN_BCC=<your inbox> to BCC every order confirmation.
#   5. SITE_BASE_URL is used to build the "view order" link in the email
#      (e.g. https://halilov.com). Leave empty in dev.
EMAIL_PROVIDER=log
EMAIL_FROM=no-reply@halilov.local
EMAIL_FROM_NAME=Halilov Market
EMAIL_ADMIN_BCC=
SITE_BASE_URL=
BREVO_API_KEY=

# pg_dump sidecar — only used with `--profile backup`. Any S3-compatible target
# works (Cloudflare R2, Oracle OS, Backblaze B2). Reuse R2 values or split.
#   docker compose -f infra/docker-compose.prod.yml --profile backup up -d --build
BACKUP_CRON=15 3 * * *
BACKUP_RETENTION_DAYS=14
BACKUP_S3_ENDPOINT=
BACKUP_S3_BUCKET=
BACKUP_S3_PREFIX=halilov/postgres
BACKUP_S3_REGION=auto
BACKUP_S3_ACCESS_KEY_ID=
BACKUP_S3_SECRET_ACCESS_KEY=

# Edge nginx config file — relative to infra/nginx/.
#   nginx.conf      HTTP-only (default, fine until you have a domain)
#   nginx.tls.conf  HTTPS on 443 with Cloudflare Origin Cert + 80→443 redirect
NGINX_CONF_FILE=nginx.conf

# ─── Cloudflare Origin Cert setup (do once when you have a domain) ───
# 1. Buy a domain. Point its nameservers at Cloudflare (free plan is fine).
# 2. In Cloudflare dashboard → DNS, add A records:
#       @       → <VM public IP>      (orange-cloud proxy ON)
#       admin   → <VM public IP>      (orange-cloud proxy ON)
# 3. SSL/TLS → Overview → set mode to "Full (strict)".
# 4. SSL/TLS → Origin Server → "Create Certificate" → 15-year RSA → Save the
#    certificate PEM as infra/nginx/certs/origin.pem on the VM, and the private
#    key as infra/nginx/certs/origin.key. Both files are gitignored (*.pem/*.key).
# 5. Set NGINX_CONF_FILE=nginx.tls.conf above, then:
#       docker compose -f infra/docker-compose.prod.yml up -d --build
# 6. Verify: curl -I https://yourdomain.tld  (should be 200 from edge, no cert warning)
